{
  "language": "english",
  "language_name": "English",
  "script": "Latin",
  "font_family": "Inter, system-ui, sans-serif",
  "keyboard_type": ["QWERTY", "DVORAK", "COLEMAK"],
  "script_direction": "ltr",
  
  "test_sentence_count": 5,
  "prompt_visibility_modes": [
    "visible",
    "faded",
    "blurred",
    "hidden",
    "timed_reveal"
