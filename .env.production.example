# Domain used by Caddy for TLS + routing.
DOMAIN=app.example.com
ACME_EMAIL=you@example.com

# Atlas MongoDB connection string.
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.xxxxx.mongodb.net/keystroke-research?retryWrites=true&w=majority&appName=Cluster0

# Backend secrets.
JWT_SECRET=replace-with-long-random-value
ADMIN_PANEL_PASSWORD=replace-with-long-random-value
ADMIN_AUTH_SECRET=replace-with-long-random-value
ADMIN_TOKEN_TTL_SECONDS=3600

# App behavior.
TRUST_PROXY=true
STORE_TYPED_TEXT=false
REQUEST_BODY_LIMIT=2mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=600000
ADMIN_LOGIN_RATE_LIMIT_MAX=5
MAX_KEYSTROKES_PER_SESSION=3000
MAX_WINDOW_EVENTS_PER_SESSION=500
MAX_SUSPICIOUS_EVENTS_PER_SESSION=500
MAX_ERROR_BURSTS_PER_SESSION=1000
MAX_SENTENCE_TEXT_LENGTH=1000
EXPORT_DEFAULT_PAGE_SIZE=500
EXPORT_MAX_PAGE_SIZE=2000
